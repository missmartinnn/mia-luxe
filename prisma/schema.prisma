// prisma/schema.prisma

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// 1. User Account Model (Authentication & Authorization)
model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String?
  role         String   @default("customer") // "customer" or "admin"
  orders       Order[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("users")
}

// 2. Product Catalog Model (Tailored for Fashion Inventory)
model Product {
  id          String      @id @default(uuid())
  name        String
  description String      @db.Text
  price       Float
  images      String[]    // Array of image URLs for luxury sliders
  category    String      // e.g., "Dresses", "Men", "Accessories"
  sizes       String[]    // e.g., ["XS", "S", "M", "L", "XL"]
  colors      String[]    // e.g., ["Pastel Pink", "Cream", "Black"]
  stock       Int         @default(0)
  orderItems  OrderItem[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@map("products")
}

// 3. Order Summary Model (Tracks Completed Checkout Invoices)
model Order {
  id              String      @id @default(uuid())
  userId          String?
  user            User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  customerName    String
  customerEmail   String
  shippingAddress String      @db.Text
  totalAmount     Float
  paymentStatus   String      @default("pending") // "pending", "paid", "failed"
  orderStatus     String      @default("processing") // "processing", "shipped", "delivered"
  items           OrderItem[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@map("orders")
}

// 4. Order Item Model (Breaks Down Individual Items inside an Order)
model OrderItem {
  id        String   @id @default(uuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  quantity  Int
  price     Float    // Historical price at the exact split-second of purchase
  size      String   // Specific size ordered
  color     String   // Specific color ordered

  @@map("order_items")
}