generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// 1. User Account Model (Authentication & Authorization)
model User {
  id            String    @id @default(uuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? // Required by NextAuth
  image         String?   // Required by NextAuth (Google Profile Pic)
  passwordHash  String?   // Optional now! (Google users won't have one)
  role          String    @default("customer") // "customer", "seller", "admin"
  
  // Customer Profile Details
  phone         String?   
  address       String?   @db.Text 
  
  // ---> NEW: Super Admin Ban System <---
  isBanned      Boolean   @default(false)
  
  accounts      Account[]
  sessions      Session[]
  orders        Order[]
  stores        Store[]   // Links sellers to their stores
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("users")
}

// 2. NextAuth OAuth Account Model
model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

// 3. NextAuth Session Model
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// 4. NextAuth Verification Token Model (For Email Magic Links / Password Resets)
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// 5. Store Model (The Vendor's Shop)
model Store {
  id              String    @id @default(uuid())
  name            String
  description     String?   @db.Text
  ownerId         String
  owner           User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  products        Product[]
  
  // ---> NEW: Super Admin Verification System <---
  status          String    @default("pending") // "pending", "verified", "rejected"
  verificationDoc String?   @db.Text            // URL to their business license/proof

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("stores")
}

// 6. Product Catalog Model (Tailored for Fashion Inventory)
model Product {
  id          String      @id @default(uuid())
  name        String
  description String      @db.Text
  price       Float
  images      String[]    // Array of image URLs for luxury sliders
  category    String      // e.g., "Dresses", "Men", "Accessories"
  subcategory String
  sizes       String[]    // e.g., ["XS", "S", "M", "L", "XL"]
  colors      String[]    // e.g., ["Pastel Pink", "Cream", "Black"]
  stock       Int         @default(0)
  
  storeId     String?     // Links the product to a specific store
  store       Store?      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  
  orderItems  OrderItem[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@map("products")
}

// 7. Order Summary Model (Tracks Completed Checkout Invoices)
model Order {
  id              String      @id @default(uuid())
  userId          String?
  user            User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  customerName    String
  customerEmail   String
  customerPhone   String?     // Track phone used for this specific order
  shippingAddress String      @db.Text
  totalAmount     Float
  paymentStatus   String      @default("pending") // "pending", "paid", "failed", "refunded"
  orderStatus     String      @default("processing") // "processing", "shipped", "delivered", "cancelled"
  items           OrderItem[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@map("orders")
}

// 8. Order Item Model (Breaks Down Individual Items inside an Order)
model OrderItem {
  id        String   @id @default(uuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  quantity  Int
  price     Float    // Historical price at the exact split-second of purchase
  size      String   // Specific size ordered
  color     String   // Specific color ordered

  @@map("order_items")
}